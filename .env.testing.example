# Copy to .env.testing if you want Laravel to load extra test-only vars
# (optional). PHPUnit sets the database via phpunit.xml; see below.
#
# PostgreSQL "testing" database
# ------------------------------
# With Laravel Sail: the `pgsql` service runs create-testing-database.sql on
# first init, which creates a `testing` database alongside your main DB.
# Run tests with either:
#   ./vendor/bin/sail artisan test
#   php artisan test   (from the host, Postgres must be reachable on 127.0.0.1)
#
# Host machine: forward Postgres (compose FORWARD_DB_PORT, default 5432).
# Tests use DB_USERNAME and DB_PASSWORD from your main .env (same user as the
# pgsql service). phpunit.xml only overrides DB_DATABASE=testing. To force a
# DB host, set TEST_DB_HOST (e.g. 127.0.0.1).
#
# Create the database manually if needed:
#   psql -h 127.0.0.1 -U sail -d postgres -c "CREATE DATABASE testing;"

APP_ENV=testing
